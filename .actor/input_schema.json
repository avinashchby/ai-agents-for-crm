{
  "title": "AI Agents for CRM Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum number of AI CRM tools to return across all sources.",
      "default": 25,
      "minimum": 1,
      "maximum": 200,
      "editor": "number"
    },
    "crmPlatform": {
      "title": "CRM Platform",
      "type": "string",
      "description": "Filter results by CRM platform compatibility.",
      "default": "all",
      "enum": ["all", "salesforce", "hubspot", "pipedrive"],
      "enumTitles": ["All Platforms", "Salesforce", "HubSpot", "Pipedrive"],
      "editor": "select"
    },
    "capabilities": {
      "title": "Capabilities Filter",
      "type": "array",
      "description": "Return only tools matching at least one of the selected capabilities. Leave empty to return all.",
      "default": [],
      "items": {
        "type": "string",
        "enum": [
          "data-enrichment",
          "email-drafting",
          "forecasting",
          "call-logging"
        ]
      },
      "editor": "stringList"
    },
    "minRating": {
      "title": "Minimum Rating",
      "type": "number",
      "description": "Only return tools with an average rating at or above this value (0–5 scale).",
      "default": 0,
      "minimum": 0,
      "maximum": 5,
      "editor": "number"
    },
    "pricingModel": {
      "title": "Pricing Model",
      "type": "string",
      "description": "Filter results by pricing model.",
      "default": "all",
      "enum": ["all", "free", "freemium", "paid"],
      "enumTitles": ["All Pricing", "Free", "Freemium", "Paid"],
      "editor": "select"
    }
  }
}
